[resource]
script = ExtResource("1_71g1o")
title = "November 18, 1929  Oloko Market"
description = "The Oloko market is alive with noise.
Palm oil traders argue loudly over falling prices. Garri sellers complain that buyers are cautious. Rumours spread quickly that a British agent had been asking women questions about property. Some traders seem nervous. But business must continue. Today’s palm oil price is low."
event_image = ExtResource("1_7h4bb")
event_audio = ExtResource("1_qya7g")
background_audio = ExtResource("1_jumh8")
option_a_text = "Buy 15 units of palm oil at a low price"
option_b_text = "Wait and observe the tension"
option_a_good_name = "palm_oil"
option_a_quantity = 15
next_event_index_a = 1
