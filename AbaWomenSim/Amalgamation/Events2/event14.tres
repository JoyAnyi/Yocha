[resource]
script = ExtResource("1_0ibn4")
title = "Growing Political Awareness."
description = "In Lagos and other Southern cities, educated Nigerians increasingly criticize colonial administration through newspapers and political discussions. Many demand stronger African representation in governance and question decisions being imposed without consultation."
event_image = ExtResource("1_jw2xr")
type = "political"
option_a_text = " Allow greater political discussion"
option_b_text = " Restrict criticism of colonial policy"
