[resource]
script = ExtResource("1_j3d4e")
title = "Warrant Chiefs Begin to Resign."
description = "Warrant Chiefs Begin to Resign. Some Warrant Chiefs begin to step down after days of relentless protests. Women celebrate in the streets, singing and dancing as authority weakens. Markets are unstable. Some traders flee, while others rush to take advantage of the confusion. No one knows what will happen next."
