[resource]
script = ExtResource("1_8v0vk")
title = "Order is Restored."
description = "The protests begin to fade. Colonial troops gradually withdraw as order is restored across the region. Markets reopen, though many traders return cautiously after weeks of unrest. The memory of the violence lingers, but trade slowly resumes. Prices begin to stabilise as supply returns. Life moves forward, but nothing feels exactly the same."
