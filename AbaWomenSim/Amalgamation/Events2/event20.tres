[resource]
script = ExtResource("1_3grlo")
title = "The Legacy of Amalgamation."
description = "Although amalgamation creates one colony called Nigeria, deep cultural, political, and economic differences remain between regions. The decisions made during British colonial rule will shape future debates about identity, governance, representation, and national unity for generations to come."
event_image = ExtResource("1_meyk7")
type = "political"
option_a_text = " View amalgamation as necessary unity"
option_b_text = " Reflect on its lasting divisions"
