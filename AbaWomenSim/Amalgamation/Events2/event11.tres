[resource]
script = ExtResource("1_fc7sl")
title = "A New Advisory Council."
description = "The British establish the Nigerian Council to bring representatives from different provinces into discussions about administration. However, the council has limited authority, and many Nigerians believe it exists mainly to support colonial decisions rather than represent local interests."
event_image = ExtResource("1_m7xsb")
type = "political"
option_a_text = " Expand the council’s influence"
option_b_text = " Keep authority with colonial officers"
next_event_index_a = 11
next_event_index_b = 11
