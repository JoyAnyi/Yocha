[resource]
script = ExtResource("1_aaaye")
title = "Suspicion of Direct Taxation"
description = "Captain Cook begins revising the nominal roll for taxation in Oloko, Bende, and Umuahia.
Women fear that this is a prelude to taxing them, just as men were taxed the previous year.
Rumors spread quickly, causing tension in the markets and neighborhoods."
event_image = ExtResource("1_2ggim")
option_a_text = " Buy 15 mudu of garri at low price"
option_b_text = " Wait and observe market tension"
option_a_good_name = "garri"
option_a_quantity = 15
option_a_risk_change = 1
