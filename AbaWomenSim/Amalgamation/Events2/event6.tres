[resource]
script = ExtResource("1_y8obr")
title = "Balancing the Colonial Economy"
description = "British officials present financial reports comparing Northern and Southern Nigeria. The North struggles with administrative deficits, while the South generates stronger customs revenue through Lagos and coastal trade. Lugard argues that combining both protectorates would create a financially stable colony. Critics warn that the South may end up funding Northern administration without equal political influence."
type = "political"
option_a_text = "Support financial amalgamation"
option_b_text = "Oppose merging the budgets"
next_event_index_a = 6
next_event_index_b = 6
influence_change_a = 12
influence_change_b = 4
stability_change_a = -6
stability_change_b = 5
