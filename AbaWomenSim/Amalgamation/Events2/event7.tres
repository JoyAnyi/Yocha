[resource]
script = ExtResource("1_024oy")
title = "Nationalists React."
description = "Educated elites and newspaper publishers in Lagos begin criticizing the proposed amalgamation. Some fear that the South’s political progress and Western-style institutions may be weakened under a centralized colonial system. Others argue that Nigerians themselves were never consulted about the merger."
event_image = ExtResource("1_06ymf")
type = "political"
option_a_text = " Ignore the criticism and proceed"
option_b_text = " Consult local representatives"
