[resource]
script = ExtResource("1_hqe4j")
title = "Traditional Rulers Under Empire."
description = "Lugard promotes indirect rule, especially in Northern Nigeria. Instead of replacing local rulers entirely, Britain governs through emirs and traditional authorities. Supporters say this preserves order and stability. Critics argue it limits political modernization and strengthens colonial control indirectly."
event_image = ExtResource("1_xiahy")
type = "political"
option_a_text = " Expand indirect rule"
option_b_text = " Introduce direct administration"
next_event_index_a = 13
next_event_index_b = 13
