[resource]
script = ExtResource("1_0lhxg")
title = "Women Surround Colonial Offices."
description = "Large groups of protesting women gather outside colonial administrative offices demanding answers about rumored taxation and the authority of warrant chiefs. Officials remain inside the buildings while the crowd grows louder. Traders nearby become nervous as the situation threatens to disrupt the market."
price_multiplier = 2.4
risk_level = 7
option_a_text = "Sell 3 mudu of garri quickly before the market closes"
option_b_text = "Keep your goods and watch how the protest develops"
option_a_good_name = "garri"
option_a_quantity = -3
