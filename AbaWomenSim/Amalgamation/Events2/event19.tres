[resource]
script = ExtResource("1_6oa34")
title = "The Amalgamation of Nigeria."
description = "On January 1st, 1914, the Colony and Protectorate of Southern Nigeria officially merges with the Northern Nigeria Protectorate. Frederick Lugard becomes Governor-General of the newly unified Nigeria. Britain presents the merger as a major administrative achievement designed to improve efficiency and financial stability across the colony."
event_image = ExtResource("1_6xppk")
type = "political"
option_a_text = " Celebrate the new unified colony"
option_b_text = " Question the long-term consequences"
next_event_index_a = 19
next_event_index_b = 19
