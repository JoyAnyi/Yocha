[resource]
script = ExtResource("1_6o8jy")
title = "Crowds Arrive from Nearby Villages."
description = "Word spreads quickly through market networks. Women from nearby villages begin arriving in Oloko to discuss the rumours of taxation. The market grows crowded and noisy. Demand for food rises as travellers buy supplies, but tension is clearly building."
