[resource]
script = ExtResource("1_71g1o")
title = "November 18, 1929  Oloko Market"
description = "The Oloko market is alive with noise.
Palm oil traders argue loudly over falling prices. Garri sellers complain that buyers are cautious. Rumors spread quickly a British agent has been asking women questions about property. Some traders seem nervous. But business must continue. Today’s palm oil price is low."
option_a_text = "Buy 15 units of palm oil at a low price"
option_b_text = "Wait and observe the tension"
option_a_good_name = "palm_oil"
option_a_quantity = 15
metadata/_custom_type_script = "uid://bta3yt8x4kxuq"
