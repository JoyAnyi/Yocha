[resource]
script = ExtResource("1_uw1ov")
title = "Counting of Livestock Causes Unease"
description = "Captain Cook revises the nominal rolls in Oloko, counting livestock and household members.
Merchants notice that buyers are cautious and some goods start disappearing from the market.
Rumors spread that taxation may soon affect women, creating tension and uncertainty in trading."
option_a_text = " Buy 3 units of palm oil quickly"
option_b_text = " Hold your money and watch the market"
option_a_good_name = "palm_oil"
option_a_quantity = 3
option_a_risk_change = 2
