[resource]
script = ExtResource("1_xc4wt")
title = "Sir Frederick Lugard Takes Control."
description = "In 1912, Sir Frederick Lugard became Governor of both Northern and Southern Nigeria. Britain gave him a major assignment: prepare both protectorates for unification. Lugard believed amalgamation would improve efficiency, strengthen imperial control, and reduce financial problems in the North. However, many officials disagreed about how such a merger should happen."
type = "political"
option_a_text = "Support Lugard’s unification plans"
option_b_text = "Proceed cautiously with reforms"
next_event_index_a = 5
next_event_index_b = 5
influence_change_a = 10
influence_change_b = 5
stability_change_a = -4
stability_change_b = 5
metadata/_custom_type_script = "uid://bta3yt8x4kxuq"
