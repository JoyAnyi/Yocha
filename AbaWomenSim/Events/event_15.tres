[resource]
script = ExtResource("1_clilh")
title = "Warrant Chiefs Under Pressure"
description = "The protests do not stop. Women gather daily around the Warrant Chiefs. They sing, dance, and mock them publicly. They block their homes and offices, refusing to leave. Trade is becoming unpredictable. Some markets are crowded, others are empty. Fear and tension fill the air. Everyone is waiting to see what will happen next."
price_multiplier = 2.0
risk_level = 5
option_a_text = "Sell 3 mudu of garri in unstable markets for high profit"
option_b_text = "Avoid unstable areas and observe market changes"
option_a_good_name = "garri"
option_a_quantity = -3
option_a_is_buy = false
option_a_risk_change = 8
option_b_risk_change = 2
