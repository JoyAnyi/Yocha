[resource]
script = ExtResource("1_d5ktq")
title = "Trade Before Representation."
description = "British colonial policy focuses heavily on economic extraction. Palm oil, agricultural exports, railways, and customs revenue become central priorities. Critics argue that economic policies mainly benefit Britain, while supporters claim colonial investment is modernizing infrastructure across the region."
