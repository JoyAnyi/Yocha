script = ExtResource("1_yq01i")
title = "Aba Commission of Inquiry."
description = "Colonial authorities launch an official inquiry into the events of the revolt. Witnesses are called from different regions to explain what happened. Traders gather in markets to discuss the hearings and share stories of the protests. Although many voices are heard, some feel that women, who led the movement, are not fully represented. Trade continues as the region slowly recovers, but attention is now focused on potential changes."
