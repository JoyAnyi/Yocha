[resource]
script = ExtResource("1_p087f")
title = "Palm-Leaf Messages Spread."
description = "News of the argument spreads quickly. Women begin sending palm-leaf messages to nearby villages, a traditional signal calling others to gather. Groups of women begin arriving in increasing numbers. The market becomes crowded as travellers buy food and supplies before attending the gatherings."
