[resource]
script = ExtResource("1_s6b6x")
title = "Colonial Officials Arrive."
description = "Colonial officials and police arrive in the area to observe the protests spreading across the region. Their presence makes the market tense. Some traders fear the market may close if trouble begins, while buyers rush to purchase goods before anything happens."
price_multiplier = 2.2
risk_level = 6
option_a_text = "Sell 2 units of salt to buyers preparing for uncertainty"
option_b_text = " Hold your goods and wait to see how the officials react"
option_a_good_name = "salt"
option_a_quantity = 2
option_a_is_buy = false
option_a_risk_change = 3
option_b_risk_change = 2
