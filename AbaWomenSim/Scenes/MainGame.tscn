[sub_resource type="Resource" id="Resource_s87t3"]
script = ExtResource("2_xr3nn")
title = "Oloko Women Gather in the Square"
description = "Women gather in the town square after hearing about livestock counting.
Rumors of taxation spread, making traders wary. Prices fluctuate as buyers hesitate.
Merchants must decide whether to act opportunistically or play it safe."
price_multiplier = 1.3
risk_level = 3
option_a_text = " Buy 10 mudu of garri quickly"
option_b_text = " Observe market trends and wait"
option_a_good_name = "garri"
option_a_quantity = 2
option_a_risk_change = 3
option_b_risk_change = 1
metadata/_custom_type_script = "uid://bta3yt8x4kxuq"

[sub_resource type="Resource" id="Resource_68ygn"]
script = ExtResource("2_xr3nn")
title = "The Argument at Oloko"
description = "A loud argument breaks out between Nwanyeruwa and the warrant chief's messenger, Mark Emereuwa. She refuses to be counted for taxation, insisting that women should not be taxed. Traders stop to watch as word spreads quickly through the market. Some buyers begin purchasing goods in panic, fearing trouble ahead."
price_multiplier = 1.6
risk_level = 4
option_a_text = " Sell 3 mudu of garri to anxious buyers"
option_b_text = " Keep your goods and observe the growing argument"
option_a_good_name = "garri"
option_a_quantity = -3
option_a_is_buy = false
option_a_risk_change = 3
option_b_risk_change = 2
metadata/_custom_type_script = "uid://bta3yt8x4kxuq"

