[resource]
script = ExtResource("1_hh3m4")
title = "Two Protectorates, One Empire."
description = "By the early 1900s, Britain governed the region now called Nigeria through two separate administrations: the Northern Nigeria Protectorate and the Southern Nigeria Protectorate. The South generated strong customs revenue through Lagos ports and coastal trade, while the North faced rising administrative costs and lower income. British officials in London began discussing whether both territories should eventually be merged into a single colony for easier control and economic balance."
price_multiplier = 1.2
risk_level = 1
type = "political"
option_a_text = "Study plans for future unification"
option_b_text = "Keep both protectorates separate"
option_a_is_buy = false
next_event_index_a = 1
next_event_index_b = 1
influence_change_a = 5
influence_change_b = 2
stability_change_a = 2
stability_change_b = 5
metadata/_custom_type_script = "uid://bta3yt8x4kxuq"
