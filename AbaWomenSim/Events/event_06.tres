[resource]
script = ExtResource("1_aiur6")
title = "The Argument at Oloko."
description = "A loud argument breaks out between Nwanyeruwa and the warrant chief's messenger, Mark Emereuwa. She refuses to be counted for taxation, insisting that women should not be taxed. Traders stop to watch as word spreads quickly through the market. Some buyers begin purchasing goods in panic, fearing trouble ahead."
price_multiplier = 1.6
risk_level = 4
option_a_text = " Sell 3 units of garri to anxious buyers"
option_b_text = " Keep your goods and observe the growing argument"
option_a_good_name = "garri"
option_a_quantity = -3
option_a_is_buy = false
option_a_risk_change = 3
option_b_risk_change = 2
metadata/_custom_type_script = "uid://bta3yt8x4kxuq"
