[resource]
script = ExtResource("1_gf244")
title = "Colonial Budgets. Under Pressure."
description = " As railway construction and administration expanded, colonial spending increased rapidly. Southern Nigeria generated revenue through trade and customs duties, but the Northern Protectorate struggled financially. British officials worried that maintaining two separate administrations was expensive. Some believed combining both territories would allow Southern revenue to support Northern administration."
event_image = ExtResource("1_6nb4x")
type = "political"
option_a_text = "Explore a shared colonial budget"
option_b_text = "Keep finances fully separate"
next_event_index_a = 4
